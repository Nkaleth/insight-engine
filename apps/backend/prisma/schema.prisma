generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model RawNeed {
  id        String                      @id @default(uuid())
  content   String
  sourceUrl String
  embedding Unsupported("vector(768)")?
  createdAt DateTime                    @default(now())
}

/// Comentarios de YouTube y posts de Reddit vectorizados para análisis semántico.
model Comment {
  id         String                      @id @default(uuid())
  sourceType String                      // 'youtube' | 'reddit'
  sourceId   String                      // videoId o subreddit name
  externalId String?                     // YouTube commentId o Reddit permalink
  author     String?
  content    String
  likeCount  Int                         @default(0)
  embedding  Unsupported("vector(768)")?
  createdAt  DateTime                    @default(now())

  @@unique([sourceId, externalId])
  @@index([sourceId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}
